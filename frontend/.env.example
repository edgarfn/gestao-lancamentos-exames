# Variáveis de ambiente do frontend (prefixo VITE_ — expostas ao navegador,
# portanto NUNCA coloque segredos aqui).
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Cloudflare Turnstile (CAPTCHA anti-bot exibido no login) — chave PÚBLICA
# (site key) do par gerado em https://dash.cloudflare.com/?to=/:account/turnstile.
# O valor abaixo é a chave de teste oficial da Cloudflare (sempre aprova o
# desafio) — combine com TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# no backend. Em produção, substitua pela site key real do seu site.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
