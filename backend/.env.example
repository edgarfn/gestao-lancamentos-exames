# ==============================================================================
# Variáveis de ambiente — BACKEND
# Copie este arquivo para ".env" e preencha com valores reais.
# NUNCA commite o arquivo ".env" com segredos reais.
# Em produção, utilize um gerenciador de segredos (Vault, AWS Secrets Manager,
# Azure Key Vault, Doppler, etc.) em vez de arquivos .env.
# ==============================================================================

NODE_ENV=development
PORT=3001

# URL de conexão com o PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL=postgresql://exames_app:troque-esta-senha@localhost:5432/exames_db?schema=public

# Segredos de autenticação — gere valores aleatórios fortes (>= 32 bytes), ex:
#   openssl rand -base64 48
JWT_ACCESS_SECRET=troque-este-segredo-de-acesso-para-um-valor-aleatorio-forte
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh-para-um-valor-aleatorio-diferente
JWT_REFRESH_EXPIRES_IN=7d

# Chave de cifragem de campos sensíveis (AES-256-GCM exige 32 bytes em base64), ex:
#   openssl rand -base64 32
DATA_ENCRYPTION_KEY=troque-esta-chave-base64-de-32-bytes-gerada-com-openssl

# Cloudflare Turnstile (CAPTCHA anti-bot exibido no login) — chave SECRETA do
# par site/secret gerado em https://dash.cloudflare.com/?to=/:account/turnstile.
# Em desenvolvimento, use a chave de teste oficial da Cloudflare abaixo, que
# sempre aprova o desafio (combine com VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# no frontend). Em produção, substitua pela chave secreta real do seu site.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# CORS — origens permitidas (separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting (proteção contra força bruta)
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=5

# Política de retenção de dados (LGPD) — dias até anonimização de registros inativos
DATA_RETENTION_DAYS=1825

# Backup e restauração do banco de dados — diretório onde os arquivos .dump
# ficam armazenados (deve ser um volume persistente, separado do volume do
# PostgreSQL) e por quantos dias mantê-los antes da limpeza automática diária.
BACKUP_DIR=/var/backups/exames
BACKUP_RETENTION_DIAS=30

# Nível de log estruturado (não deve registrar dados pessoais)
LOG_LEVEL=info

# ==============================================================================
# Recuperação de senha por e-mail — todos os campos são OPCIONAIS.
# Se SMTP_HOST não for definido, o link de recuperação será apenas logado no
# console (útil em desenvolvimento). Em produção, configure um servidor SMTP.
# ==============================================================================
# SMTP_HOST=smtp.exemplo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=usuario@exemplo.com
# SMTP_PASS=senha-do-smtp
# SMTP_FROM=noreply@clinica.com

# URL pública do frontend — usada para montar o link de recuperação de senha
# enviado por e-mail. Em produção, informe a URL real (ex.: https://clinica.com).
FRONTEND_URL=http://localhost:8089

# ==============================================================================
# Redis — OPCIONAL (rate limiting distribuído)
# Sem esta variável, o rate limiting usa memória local (uma instância).
# Com Redis, múltiplas instâncias do backend compartilham os mesmos contadores,
# impedindo que um ataque de força bruta contorne o limite trocando de instância.
# ==============================================================================
# REDIS_URL=redis://localhost:6379
