# ==============================================================================
# Variáveis de ambiente — ORQUESTRAÇÃO (docker compose)
# Copie este arquivo para ".env" na raiz do projeto e preencha com valores
# reais antes de rodar `docker compose up`.
#
# NUNCA commite o arquivo ".env" com segredos reais. Em produção, prefira um
# gerenciador de segredos dedicado (Vault, AWS Secrets Manager, Doppler etc.).
#
# Gere segredos fortes com, por exemplo:
#   openssl rand -base64 48   (para os segredos JWT)
#   openssl rand -base64 32   (para a chave de cifragem AES-256-GCM)
# ==============================================================================

# --- Banco de dados PostgreSQL ------------------------------------------------
POSTGRES_USER=exames_app
POSTGRES_PASSWORD=troque-esta-senha-por-um-valor-aleatorio-forte
POSTGRES_DB=exames_db
# Apenas usado pelo overlay docker-compose.dev.yml (porta publicada no host).
# 5433 evita colidir com uma instância nativa do PostgreSQL na porta 5432.
POSTGRES_PORT=5433

# --- Backend (NestJS) ---------------------------------------------------------
JWT_ACCESS_SECRET=troque-este-segredo-de-acesso-para-um-valor-aleatorio-forte
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh-para-um-valor-aleatorio-diferente
JWT_REFRESH_EXPIRES_IN=7d

# Chave de cifragem de campos sensíveis (AES-256-GCM exige 32 bytes em base64)
DATA_ENCRYPTION_KEY=troque-esta-chave-base64-de-32-bytes-gerada-com-openssl

# Cloudflare Turnstile (CAPTCHA anti-bot no login) — par site/secret gerado em
# https://dash.cloudflare.com/?to=/:account/turnstile. Os valores abaixo são as
# chaves de TESTE oficiais da Cloudflare (sempre aprovam o desafio) — adequadas
# para desenvolvimento. Em produção, substitua pelas chaves reais do seu site.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

CORS_ALLOWED_ORIGINS=http://localhost:8089
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=5
DATA_RETENTION_DAYS=1825
LOG_LEVEL=info

# Backup e restauração do banco — diretório (dentro do contêiner do backend,
# montado como volume persistente "backup_data") onde os arquivos .dump ficam
# armazenados, e por quantos dias mantê-los antes da limpeza automática diária.
BACKUP_DIR=/var/backups/exames
BACKUP_RETENTION_DIAS=30

# Uploads de configurações da clínica (logotipo, etc.) — diretório dentro do
# contêiner do backend, montado como volume persistente "configuracoes_data".
CONFIGURACOES_DIR=/var/uploads/configuracoes

# --- Frontend (build-time) -----------------------------------------------------
# Caminho relativo: o nginx do frontend faz proxy reverso de /api/ para o backend
VITE_API_BASE_URL=/api/v1
FRONTEND_PORT=8089

# --- Apenas docker-compose.dev.yml ---------------------------------------------
ADMINER_PORT=8081

# --- HTTPS / Caddy (apenas overlay docker-compose.https.yml) -------------------
# Domínio público com registro DNS do tipo A/AAAA apontando para este servidor.
DOMAIN=exames.suaempresa.com.br
# E-mail usado pelo Let's Encrypt para avisos sobre o certificado (obrigatório).
ACME_EMAIL=admin@suaempresa.com.br
# Lembre-se de também atualizar CORS_ALLOWED_ORIGINS para "https://SEU_DOMINIO"
# ao habilitar HTTPS — veja docs/CONFIGURACAO_HTTPS.md para o passo a passo.
